@model IEnumerable<MyProject.Application.DTOs.MedicineDto>

@{
    ViewData["Title"] = "Medicines Catalogue";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-slate-800 fw-bold">Medicines Catalogue</h1>
            <p class="text-muted small mb-0">Manage hospital pharmacy inventory, units, and pricing.</p>
        </div>
        <button type="button" class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createMedicineModal">
            <i class="fa-solid fa-plus-circle"></i> Add Medicine
        </button>
    </div>

    <!-- Advanced Search / Filters Panel -->
    <div class="modern-card" style="padding: 20px;">
        <h6 class="fw-bold text-slate-700 mb-3"><i class="fa-solid fa-sliders me-2"></i>Inventory Filters</h6>
        <form method="get" asp-action="Index">
            <div class="search-card-filters">
                <div class="form-group-custom" style="flex: 2;">
                    <label class="form-label-custom">Medicine Name</label>
                    <input type="text" name="searchName" value="@ViewBag.SearchName" class="form-control-custom" placeholder="Search medicines by name..." />
                </div>
                
                <div class="form-group-custom">
                    <label class="form-label-custom">Unit Type</label>
                    <select name="filterUnit" class="form-control-custom" style="padding: 9px 12px;">
                        <option value="All">All Units</option>
                        <option value="Tablet" selected="@(ViewBag.FilterUnit == "Tablet")">Tablet</option>
                        <option value="Capsule" selected="@(ViewBag.FilterUnit == "Capsule")">Capsule</option>
                        <option value="Bottle" selected="@(ViewBag.FilterUnit == "Bottle")">Bottle</option>
                        <option value="Injection" selected="@(ViewBag.FilterUnit == "Injection")">Injection</option>
                        <option value="Tube" selected="@(ViewBag.FilterUnit == "Tube")">Tube</option>
                    </select>
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom">Min Price (VND)</label>
                    <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control-custom" placeholder="Min" />
                </div>

                <div class="form-group-custom">
                    <label class="form-label-custom">Max Price (VND)</label>
                    <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control-custom" placeholder="Max" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom" style="padding: 10px 18px;">
                        <i class="fa-solid fa-magnifying-glass"></i> Filter
                    </button>
                    <a asp-action="Index" class="btn-secondary-custom" style="padding: 10px 18px;">Reset</a>
                </div>
            </div>
        </form>
    </div>

    <!-- Medicines List Table -->
    <div class="modern-card modern-table-card">
        <div class="modern-table-header">
            <h5 class="modern-table-title">Medicine Roster (@Model.Count() items)</h5>
        </div>
        <div class="table-responsive">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Medicine Name</th>
                        <th>Unit</th>
                        <th>Price</th>
                        <th>Stock Qty</th>
                        <th>Status</th>
                        <th class="text-end" style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-pills fa-2x mb-3 text-secondary"></i>
                                <p class="mb-0">No medicines found matching the filters.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            var status = "In Stock";
                            var badgeClass = "badge-active";
                            if (item.StockQuantity == 0)
                            {
                                status = "Out of Stock";
                                badgeClass = "badge-danger";
                            }
                            else if (item.StockQuantity <= 50)
                            {
                                status = "Low Stock";
                                badgeClass = "badge-waiting";
                            }

                            <tr>
                                <td class="fw-bold text-secondary">#@item.MedicineId</td>
                                <td class="fw-bold text-slate-800">@item.Name</td>
                                <td>
                                    <span class="badge bg-light text-dark border px-3 py-1 rounded-pill" style="font-size: 11px;">@item.Unit</span>
                                </td>
                                <td class="fw-bold text-slate-850">
                                    @item.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))
                                </td>
                                <td>@item.StockQuantity</td>
                                <td>
                                    <span class="modern-badge @badgeClass">
                                        <i class="fa-solid fa-circle" style="font-size: 6px;"></i> @status
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <button type="button" class="table-action-icon" title="Edit Medicine"
                                                onclick="openEditMedicineModal(@item.MedicineId, '@item.Name.Replace("'", "\\'")', '@item.Unit', @item.Price, @item.StockQuantity)">
                                            <i class="fa-solid fa-pen"></i>
                                        </button>
                                        <a asp-action="Details" asp-route-id="@item.MedicineId" class="table-action-icon" title="View Details">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <button type="button" class="table-action-icon danger-hover" title="Delete Medicine"
                                                    onclick="openDeleteMedicineModal(@item.MedicineId, '@item.Name.Replace("'", "\\'")')">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="pagination-wrapper">
            <span class="pagination-info">Showing 1 to @Model.Count() of @Model.Count() entries</span>
            <div class="pagination-controls">
                <a class="pagination-btn"><i class="fa-solid fa-angle-left"></i></a>
                <a class="pagination-btn active">1</a>
                <a class="pagination-btn"><i class="fa-solid fa-angle-right"></i></a>
            </div>
        </div>
    </div>
</div>

<!-- Create Medicine Modal -->
<div class="modal fade" id="createMedicineModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-pills me-2"></i>Add New Medicine</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Medicine Name</label>
                        <input type="text" name="Name" class="form-control rounded-3" placeholder="e.g. Paracetamol 500mg" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Unit</label>
                        <input type="text" name="Unit" class="form-control rounded-3" placeholder="e.g. Tablet, Box, Bottle" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Unit Price (VND)</label>
                            <input type="number" name="Price" step="0.01" min="0" class="form-control rounded-3" placeholder="e.g. 5000" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Stock Quantity</label>
                            <input type="number" name="StockQuantity" min="0" class="form-control rounded-3" placeholder="e.g. 100" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="fa-solid fa-plus me-1"></i> Add Medicine
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Medicine Modal -->
<div class="modal fade" id="editMedicineModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-warning text-dark rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-pen me-2"></i>Edit Medicine</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editMedicineForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Medicine Name</label>
                        <input type="text" name="Name" id="editMedicineName" class="form-control rounded-3" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Unit</label>
                        <input type="text" name="Unit" id="editMedicineUnit" class="form-control rounded-3" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Unit Price (VND)</label>
                            <input type="number" name="Price" id="editMedicinePrice" step="0.01" min="0" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Stock Quantity</label>
                            <input type="number" name="StockQuantity" id="editMedicineStock" min="0" class="form-control rounded-3" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">
                        <i class="fa-solid fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteMedicineModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-trash-alt me-2"></i>Delete Medicine</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <i class="fa-solid fa-exclamation-triangle fa-3x text-danger mb-3"></i>
                <p class="mb-1">Are you sure you want to delete:</p>
                <p class="fw-bold fs-6" id="deleteMedicineName"></p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteMedicineForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        <i class="fa-solid fa-trash-alt me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditMedicineModal(id, name, unit, price, stock) {
            document.getElementById('editMedicineName').value = name;
            document.getElementById('editMedicineUnit').value = unit;
            document.getElementById('editMedicinePrice').value = price;
            document.getElementById('editMedicineStock').value = stock;
            document.getElementById('editMedicineForm').action = '/Medicines/Edit/' + id;
            new bootstrap.Modal(document.getElementById('editMedicineModal')).show();
        }

        function openDeleteMedicineModal(id, name) {
            document.getElementById('deleteMedicineName').textContent = name;
            document.getElementById('deleteMedicineForm').action = '/Medicines/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteMedicineModal')).show();
        }
    </script>
}
