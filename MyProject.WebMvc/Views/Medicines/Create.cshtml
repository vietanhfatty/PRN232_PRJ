@model MyProject.Application.DTOs.CreateMedicineRequest

@{
    ViewData["Title"] = "Add Medicine";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0 fw-bold text-primary"><i class="fa-solid fa-pills me-2"></i>Add New Medicine</h5>
                </div>
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            <div asp-validation-summary="All" class="text-danger small"></div>
                        </div>
                    }

                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold small text-muted">Medicine Name</label>
                            <input asp-for="Name" class="form-control rounded-3" required placeholder="e.g. Paracetamol 500mg" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Unit" class="form-label fw-bold small text-muted">Unit</label>
                            <input asp-for="Unit" class="form-control rounded-3" required placeholder="e.g. Tablet, Box, Bottle" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label fw-bold small text-muted">Unit Price (VND)</label>
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control rounded-3" required placeholder="e.g. 5000" />
                        </div>

                        <div class="mb-4">
                            <label asp-for="StockQuantity" class="form-label fw-bold small text-muted">Initial Stock Quantity</label>
                            <input asp-for="StockQuantity" type="number" min="0" class="form-control rounded-3" required placeholder="e.g. 100" />
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">Add Medicine</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
