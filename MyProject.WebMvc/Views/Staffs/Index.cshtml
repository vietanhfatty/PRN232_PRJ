@model IEnumerable<MyProject.Application.DTOs.StaffDto>
@using MyProject.Application.DTOs

@{
    ViewData["Title"] = "Staff Management";
    var roles = ViewBag.Roles as IEnumerable<RoleDto> ?? Enumerable.Empty<RoleDto>();
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-slate-800 fw-bold">Staff Management</h1>
            <p class="text-muted small mb-0">Manage hospital personnel records, roles, and operational status.</p>
        </div>
        <button type="button" class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createStaffModal">
            <i class="fa-solid fa-user-plus"></i> Add Staff Member
        </button>
    </div>

    <!-- Stats summary -->
    <div class="row mb-4 align-items-center">
        <div class="col-lg-8">
            <div class="d-flex gap-3">
                <div class="modern-card hover-elevate mb-0" style="padding: 16px 24px; flex: 1; display: flex; align-items: center; gap: 16px;">
                    <div class="stat-card-icon-wrapper icon-blue" style="width: 40px; height: 40px; font-size: 16px;">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted small fw-bold text-uppercase" style="font-size: 10px;">Total Staff</span>
                        <span class="fw-bold text-slate-800" style="font-size: 20px;">@Model.Count()</span>
                    </div>
                </div>
                <div class="modern-card hover-elevate mb-0" style="padding: 16px 24px; flex: 1; display: flex; align-items: center; gap: 16px;">
                    <div class="stat-card-icon-wrapper icon-green" style="width: 40px; height: 40px; font-size: 16px;">
                        <i class="fa-solid fa-user-check"></i>
                    </div>
                    <div class="d-flex flex-column">
                        <span class="text-muted small fw-bold text-uppercase" style="font-size: 10px;">On Duty</span>
                        <span class="fw-bold text-slate-800" style="font-size: 20px;">@Model.Count(s => s.Status == "Active")</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4 text-end">
            <div class="modern-card mb-0" style="padding: 16px 20px;">
                <span class="text-muted small fw-bold text-uppercase d-block text-start mb-2" style="font-size: 10px; letter-spacing: 0.5px;">Filter by Role</span>
                <div class="d-flex gap-1 justify-content-start">
                    <button class="btn-pill-filter active" onclick="filterRole('All')">All Roles</button>
                    <button class="btn-pill-filter" onclick="filterRole('Doctor')">Doctors</button>
                    <button class="btn-pill-filter" onclick="filterRole('Nurse')">Nurses</button>
                    <button class="btn-pill-filter" onclick="filterRole('Admin')">Admin</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Search -->
    <div class="row mb-3">
        <div class="col-md-4">
            <div class="search-wrapper">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                <input type="text" id="staffSearchInput" class="search-input" placeholder="Search for staff, IDs, or departments..." />
            </div>
        </div>
    </div>

    <!-- Staff Table -->
    <div class="modern-card modern-table-card">
        <div class="table-responsive">
            <table class="modern-table" id="staffTable">
                <thead>
                    <tr>
                        <th>Staff Member</th>
                        <th>Role</th>
                        <th>Department</th>
                        <th>Contact</th>
                        <th>Status</th>
                        <th class="text-end" style="width: 120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var initials = "ST";
                        if (!string.IsNullOrEmpty(item.FirstName))
                        {
                            initials = (item.FirstName[0].ToString() + (item.LastName.Length > 0 ? item.LastName[0].ToString() : "")).ToUpper();
                        }

                        var roleBadgeClass = "bg-secondary text-light";
                        var normalizedRole = item.RoleName?.ToUpper() ?? "STAFF";
                        if (normalizedRole.Contains("DOCTOR")) { roleBadgeClass = "bg-primary-subtle text-primary border border-primary-subtle"; }
                        else if (normalizedRole.Contains("NURSE")) { roleBadgeClass = "bg-purple-subtle text-purple border border-purple-subtle"; }
                        else if (normalizedRole.Contains("ADMIN")) { roleBadgeClass = "bg-success-subtle text-success border border-success-subtle"; }
                        else if (normalizedRole.Contains("RECEPTIONIST")) { roleBadgeClass = "bg-light text-dark border"; }

                        var avatarClasses = new[] { "avatar-blue", "avatar-indigo", "avatar-purple", "avatar-pink", "avatar-emerald", "avatar-rose" };
                        var avatarClass = avatarClasses[Math.Abs(item.StaffId) % avatarClasses.Length];

                        var safeFirst = item.FirstName.Replace("'", "\\'");
                        var safeLast = item.LastName.Replace("'", "\\'");
                        var safeSpec = (item.Specialization ?? "").Replace("'", "\\'");
                        var safePhone = (item.Phone ?? "").Replace("'", "\\'");
                        var safeEmail = (item.Email ?? "").Replace("'", "\\'");
                        var safeUsername = (item.Username ?? "").Replace("'", "\\'");

                        <tr class="staff-row" data-role="@(item.RoleName ?? "Staff")">
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle @avatarClass">@initials</div>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-slate-800 staff-name">@item.FirstName @item.LastName</span>
                                        <span class="text-muted" style="font-size: 11px;">ID: #@item.StaffId-STF</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge @roleBadgeClass px-3 py-1 rounded-pill" style="font-size: 11px; font-weight: 700;">@normalizedRole</span>
                            </td>
                            <td class="staff-dept">@(string.IsNullOrEmpty(item.Specialization) ? "Administration" : item.Specialization)</td>
                            <td class="staff-phone">@item.Phone</td>
                            <td>
                                @if (item.Status == "Active")
                                {
                                    <span class="modern-badge badge-active"><i class="fa-solid fa-circle" style="font-size: 6px;"></i> Active</span>
                                }
                                else
                                {
                                    <span class="modern-badge badge-scheduled"><i class="fa-solid fa-circle" style="font-size: 6px;"></i> @item.Status</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex align-items-center justify-content-end gap-2">
                                    <button type="button" class="table-action-icon" title="Edit Staff"
                                            onclick="openEditStaffModal(@item.StaffId, '@safeFirst', '@safeLast', '@safeSpec', '@safePhone', '@safeEmail', '@(item.Status ?? "Active")', '@safeUsername', @(item.RoleId.HasValue ? item.RoleId.Value.ToString() : "0"))">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <button type="button" class="table-action-icon danger-hover" title="Delete Staff"
                                                onclick="openDeleteStaffModal(@item.StaffId, '@safeFirst @safeLast')">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="pagination-wrapper">
            <span class="pagination-info" id="showingCount">Showing 1 to @Model.Count() of @Model.Count() entries</span>
            <div class="pagination-controls">
                <a class="pagination-btn"><i class="fa-solid fa-angle-left"></i></a>
                <a class="pagination-btn active">1</a>
                <a class="pagination-btn"><i class="fa-solid fa-angle-right"></i></a>
            </div>
        </div>
    </div>
</div>

<!-- Create Staff Modal -->
<div class="modal fade" id="createStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-user-plus me-2"></i>Create New Staff Member</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post" id="createStaffForm">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <h6 class="text-primary border-bottom pb-2 mb-3">1. Personal Information</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">First Name</label>
                            <input type="text" name="FirstName" class="form-control" placeholder="Enter first name" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Last Name</label>
                            <input type="text" name="LastName" class="form-control" placeholder="Enter last name" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Phone Number</label>
                            <input type="text" name="Phone" id="createStaffPhone" class="form-control" placeholder="Enter phone number" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Email Address</label>
                            <input type="email" name="Email" class="form-control" placeholder="Enter email address" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small" id="createStaffRoleLabel">System Role <span class="text-danger select-asterisk" style="display:none;">*</span></label>
                            <select name="RoleId" id="createStaffRole" class="form-select">
                                <option value="">-- Select Role --</option>
                                @foreach (var role in roles)
                                {
                                    <option value="@role.RoleId" data-role-name="@role.RoleName">@role.RoleName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 mb-3" id="createStaffSpecContainer">
                            <label class="form-label fw-bold small" id="createStaffSpecLabel">Specialization <span class="text-danger select-asterisk" style="display:none;">*</span></label>
                            <input type="text" name="Specialization" id="createStaffSpec" class="form-control" placeholder="e.g. Cardiology" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small">Status</label>
                            <select name="Status" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                    </div>
                    <h6 class="text-primary border-bottom pb-2 mb-3 mt-2">2. Account Credentials (Optional)</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small" id="createStaffUsernameLabel">Username</label>
                            <input type="text" name="Username" id="createStaffUsername" class="form-control" placeholder="Enter username" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small" id="createStaffPasswordLabel">Password <span class="text-danger select-asterisk" style="display:none;">*</span></label>
                            <input type="password" name="Password" id="createStaffPassword" class="form-control" placeholder="Enter password" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small" id="createStaffConfirmPasswordLabel">Confirm Password <span class="text-danger select-asterisk" style="display:none;">*</span></label>
                            <input type="password" id="createStaffConfirmPassword" class="form-control" placeholder="Confirm password" />
                            <div class="invalid-feedback" id="createStaffConfirmPasswordError">Passwords do not match.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="fa-solid fa-save me-1"></i> Save Staff Member
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Staff Modal -->
<div class="modal fade" id="editStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-warning text-dark rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-user-pen me-2"></i>Edit Staff Member</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editStaffForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <h6 class="text-primary border-bottom pb-2 mb-3">1. Personal Information</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">First Name</label>
                            <input type="text" name="FirstName" id="editStaffFirstName" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Last Name</label>
                            <input type="text" name="LastName" id="editStaffLastName" class="form-control" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Phone Number</label>
                            <input type="text" name="Phone" id="editStaffPhone" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small">Email Address</label>
                            <input type="email" name="Email" id="editStaffEmail" class="form-control" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small" id="editStaffRoleLabel">System Role <span class="text-danger select-asterisk" style="display:none;">*</span></label>
                            <select name="RoleId" id="editStaffRole" class="form-select">
                                <option value="">-- Select Role --</option>
                                @foreach (var role in roles)
                                {
                                    <option value="@role.RoleId" data-role-name="@role.RoleName">@role.RoleName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 mb-3" id="editStaffSpecContainer">
                            <label class="form-label fw-bold small" id="editStaffSpecLabel">Specialization <span class="text-danger select-asterisk" style="display:none;">*</span></label>
                            <input type="text" name="Specialization" id="editStaffSpec" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small">Status</label>
                            <select name="Status" id="editStaffStatus" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                            </select>
                        </div>
                    </div>
                    <h6 class="text-primary border-bottom pb-2 mb-3 mt-2">2. Account Credentials</h6>
                    <p class="text-muted small">Leave Password blank to keep current. Remove Username to delete account.</p>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small" id="editStaffUsernameLabel">Username</label>
                            <input type="text" name="Username" id="editStaffUsername" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small" id="editStaffPasswordLabel">New Password</label>
                            <input type="password" name="Password" id="editStaffPassword" class="form-control" placeholder="Leave blank to keep current" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold small" id="editStaffConfirmPasswordLabel">Confirm New Password <span class="text-danger select-asterisk" style="display:none;">*</span></label>
                            <input type="password" id="editStaffConfirmPassword" class="form-control" placeholder="Confirm new password" />
                            <div class="invalid-feedback" id="editStaffConfirmPasswordError">Passwords do not match.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">
                        <i class="fa-solid fa-save me-1"></i> Update Staff Member
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteStaffModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-trash-alt me-2"></i>Delete Staff</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <i class="fa-solid fa-exclamation-triangle fa-3x text-danger mb-3"></i>
                <p class="mb-1">Are you sure you want to delete:</p>
                <p class="fw-bold fs-6" id="deleteStaffName"></p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteStaffForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        <i class="fa-solid fa-trash-alt me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterRole(role) {
            document.querySelectorAll('.btn-pill-filter').forEach(function(btn) {
                btn.classList.toggle('active', btn.textContent.trim().includes(role) || (role === 'All' && btn.textContent.includes('All')));
            });
            var rows = document.querySelectorAll('.staff-row');
            var count = 0;
            rows.forEach(function(row) {
                var show = role === 'All' || row.getAttribute('data-role').toLowerCase().includes(role.toLowerCase());
                row.style.display = show ? '' : 'none';
                if (show) count++;
            });
            document.getElementById('showingCount').textContent = 'Showing 1 to ' + count + ' of ' + count + ' entries';
        }

        document.getElementById('staffSearchInput').addEventListener('keyup', function() {
            var val = this.value.toLowerCase().trim();
            var rows = document.querySelectorAll('.staff-row');
            var count = 0;
            rows.forEach(function(row) {
                var name = row.querySelector('.staff-name').textContent.toLowerCase();
                var phone = row.querySelector('.staff-phone').textContent.toLowerCase();
                var dept = row.querySelector('.staff-dept').textContent.toLowerCase();
                var show = name.includes(val) || phone.includes(val) || dept.includes(val);
                row.style.display = show ? '' : 'none';
                if (show) count++;
            });
            document.getElementById('showingCount').textContent = 'Showing 1 to ' + count + ' of ' + count + ' entries';
        });

        function openEditStaffModal(id, firstName, lastName, spec, phone, email, status, username, roleId) {
            document.getElementById('editStaffFirstName').value = firstName;
            document.getElementById('editStaffLastName').value = lastName;
            document.getElementById('editStaffSpec').value = spec;
            document.getElementById('editStaffPhone').value = phone;
            document.getElementById('editStaffEmail').value = email;
            document.getElementById('editStaffStatus').value = status;
            document.getElementById('editStaffUsername').value = username;
            document.getElementById('editStaffRole').value = roleId || '';
            document.getElementById('editStaffForm').action = '/Staffs/Edit/' + id;

            // Reset passwords on modal load
            document.getElementById('editStaffPassword').value = '';
            document.getElementById('editStaffConfirmPassword').value = '';
            document.getElementById('editStaffConfirmPassword').classList.remove('is-invalid');

            // Trigger visual and input constraints logic for edit modal
            toggleEditSpecialization();
            toggleEditAccountFields();
            toggleEditPasswordFields();

            new bootstrap.Modal(document.getElementById('editStaffModal')).show();
        }

        function openDeleteStaffModal(id, name) {
            document.getElementById('deleteStaffName').textContent = name;
            document.getElementById('deleteStaffForm').action = '/Staffs/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteStaffModal')).show();
        }

        function toggleCreateSpecialization() {
            var select = document.getElementById('createStaffRole');
            var selectedOption = select.options[select.selectedIndex];
            var roleName = selectedOption ? selectedOption.getAttribute('data-role-name') : '';
            var specInput = document.getElementById('createStaffSpec');
            var asterisk = document.querySelector('#createStaffSpecContainer .select-asterisk');
            
            if (roleName && roleName.toLowerCase() === 'doctor') {
                specInput.disabled = false;
                specInput.required = true;
                if (asterisk) asterisk.style.display = 'inline';
            } else {
                specInput.disabled = true;
                specInput.required = false;
                specInput.value = '';
                if (asterisk) asterisk.style.display = 'none';
            }
        }

        function toggleEditSpecialization() {
            var select = document.getElementById('editStaffRole');
            var selectedOption = select.options[select.selectedIndex];
            var roleName = selectedOption ? selectedOption.getAttribute('data-role-name') : '';
            var specInput = document.getElementById('editStaffSpec');
            var asterisk = document.querySelector('#editStaffSpecContainer .select-asterisk');
            
            if (roleName && roleName.toLowerCase() === 'doctor') {
                specInput.disabled = false;
                specInput.required = true;
                if (asterisk) asterisk.style.display = 'inline';
            } else {
                specInput.disabled = true;
                specInput.required = false;
                specInput.value = '';
                if (asterisk) asterisk.style.display = 'none';
            }
        }

        function toggleCreateAccountFields() {
            var username = document.getElementById('createStaffUsername').value.trim();
            var password = document.getElementById('createStaffPassword');
            var confirmPassword = document.getElementById('createStaffConfirmPassword');
            var roleSelect = document.getElementById('createStaffRole');
            var pwdAsterisk = document.querySelector('#createStaffPasswordLabel .select-asterisk');
            var confirmAsterisk = document.querySelector('#createStaffConfirmPasswordLabel .select-asterisk');
            var roleAsterisk = document.querySelector('#createStaffRoleLabel .select-asterisk');

            if (username.length > 0) {
                password.required = true;
                confirmPassword.required = true;
                roleSelect.required = true;
                if (pwdAsterisk) pwdAsterisk.style.display = 'inline';
                if (confirmAsterisk) confirmAsterisk.style.display = 'inline';
                if (roleAsterisk) roleAsterisk.style.display = 'inline';
            } else {
                password.required = false;
                confirmPassword.required = false;
                roleSelect.required = false;
                if (pwdAsterisk) pwdAsterisk.style.display = 'none';
                if (confirmAsterisk) confirmAsterisk.style.display = 'none';
                if (roleAsterisk) roleAsterisk.style.display = 'none';
            }
        }

        function toggleEditAccountFields() {
            var username = document.getElementById('editStaffUsername').value.trim();
            var roleSelect = document.getElementById('editStaffRole');
            var roleAsterisk = document.querySelector('#editStaffRoleLabel .select-asterisk');

            if (username.length > 0) {
                roleSelect.required = true;
                if (roleAsterisk) roleAsterisk.style.display = 'inline';
            } else {
                roleSelect.required = false;
                if (roleAsterisk) roleAsterisk.style.display = 'none';
            }
        }

        function toggleEditPasswordFields() {
            var password = document.getElementById('editStaffPassword').value;
            var confirmPassword = document.getElementById('editStaffConfirmPassword');
            var confirmAsterisk = document.querySelector('#editStaffConfirmPasswordLabel .select-asterisk');

            if (password.length > 0) {
                confirmPassword.required = true;
                if (confirmAsterisk) confirmAsterisk.style.display = 'inline';
            } else {
                confirmPassword.required = false;
                if (confirmAsterisk) confirmAsterisk.style.display = 'none';
            }
        }

        function validatePhoneField(inputElement, isSubmitOrBlur) {
            var val = inputElement.value;
            var feedback = inputElement.nextElementSibling;
            if (!feedback || !feedback.classList.contains('invalid-feedback')) {
                feedback = document.createElement('div');
                feedback.className = 'invalid-feedback';
                inputElement.parentNode.insertBefore(feedback, inputElement.nextSibling);
            }
            
            if (val.length === 0) {
                if (isSubmitOrBlur) {
                    inputElement.classList.add('is-invalid');
                    feedback.textContent = 'Phone number is required.';
                } else {
                    inputElement.classList.remove('is-invalid');
                }
                return false;
            }
            
            if (val.length >= 2 && !/^(03|05|07|09)/.test(val)) {
                inputElement.classList.add('is-invalid');
                feedback.textContent = 'Phone number must start with 03, 05, 07, or 09.';
                return false;
            }
            
            if (val.length < 10) {
                if (isSubmitOrBlur) {
                    inputElement.classList.add('is-invalid');
                    feedback.textContent = 'Phone number must be exactly 10 digits.';
                } else {
                    inputElement.classList.remove('is-invalid');
                }
                return false;
            }
            
            inputElement.classList.remove('is-invalid');
            return true;
        }

        function setupPhoneInput(phoneInput) {
            if (!phoneInput) return;
            
            phoneInput.addEventListener('input', function() {
                var cleanValue = this.value.replace(/\D/g, '');
                if (cleanValue.length > 10) {
                    cleanValue = cleanValue.substring(0, 10);
                }
                this.value = cleanValue;
                validatePhoneField(this, false);
            });
            
            phoneInput.addEventListener('blur', function() {
                validatePhoneField(this, true);
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Setup Phone Inputs
            var createPhone = document.getElementById('createStaffPhone');
            setupPhoneInput(createPhone);
            var editPhone = document.getElementById('editStaffPhone');
            setupPhoneInput(editPhone);

            // Setup Create Modal Event Listeners
            var createRole = document.getElementById('createStaffRole');
            if (createRole) {
                createRole.addEventListener('change', toggleCreateSpecialization);
            }
            var createUsername = document.getElementById('createStaffUsername');
            if (createUsername) {
                createUsername.addEventListener('input', toggleCreateAccountFields);
            }

            // Real-time password verification for Create
            var createPassword = document.getElementById('createStaffPassword');
            var createConfirmPassword = document.getElementById('createStaffConfirmPassword');
            function validateCreatePasswordMatch() {
                if (createConfirmPassword.value.length > 0 && createPassword.value !== createConfirmPassword.value) {
                    createConfirmPassword.classList.add('is-invalid');
                } else {
                    createConfirmPassword.classList.remove('is-invalid');
                }
            }
            if (createPassword && createConfirmPassword) {
                createPassword.addEventListener('input', validateCreatePasswordMatch);
                createConfirmPassword.addEventListener('input', validateCreatePasswordMatch);
            }

            // Setup Edit Modal Event Listeners
            var editRole = document.getElementById('editStaffRole');
            if (editRole) {
                editRole.addEventListener('change', toggleEditSpecialization);
            }
            var editUsername = document.getElementById('editStaffUsername');
            if (editUsername) {
                editUsername.addEventListener('input', toggleEditAccountFields);
            }

            // Real-time password verification for Edit
            var editPassword = document.getElementById('editStaffPassword');
            var editConfirmPassword = document.getElementById('editStaffConfirmPassword');
            function validateEditPasswordMatch() {
                if (editConfirmPassword.value.length > 0 && editPassword.value !== editConfirmPassword.value) {
                    editConfirmPassword.classList.add('is-invalid');
                } else {
                    editConfirmPassword.classList.remove('is-invalid');
                }
            }
            if (editPassword && editConfirmPassword) {
                editPassword.addEventListener('input', function() {
                    toggleEditPasswordFields();
                    validateEditPasswordMatch();
                });
                editConfirmPassword.addEventListener('input', validateEditPasswordMatch);
            }

            // Form submission hooks
            var createForm = document.getElementById('createStaffForm');
            if (createForm) {
                createForm.addEventListener('submit', function(e) {
                    var phone = document.getElementById('createStaffPhone');
                    if (!validatePhoneField(phone, true)) {
                        e.preventDefault();
                        phone.focus();
                        return;
                    }

                    var pwd = createPassword.value;
                    var confirm = createConfirmPassword.value;
                    if (pwd !== confirm) {
                        e.preventDefault();
                        createConfirmPassword.classList.add('is-invalid');
                        createConfirmPassword.focus();
                    }
                });
            }

            var editForm = document.getElementById('editStaffForm');
            if (editForm) {
                editForm.addEventListener('submit', function(e) {
                    var phone = document.getElementById('editStaffPhone');
                    if (!validatePhoneField(phone, true)) {
                        e.preventDefault();
                        phone.focus();
                        return;
                    }

                    var pwd = editPassword.value;
                    var confirm = editConfirmPassword.value;
                    if (pwd.length > 0 && pwd !== confirm) {
                        e.preventDefault();
                        editConfirmPassword.classList.add('is-invalid');
                        editConfirmPassword.focus();
                    }
                });
            }

            // Initial trigger for create modal inputs
            toggleCreateSpecialization();
            toggleCreateAccountFields();
        });
    </script>
}
