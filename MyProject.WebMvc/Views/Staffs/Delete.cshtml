@model MyProject.Application.DTOs.StaffDto

@{
    ViewData["Title"] = "Delete Staff";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg border-danger">
                <div class="card-header bg-danger text-white text-center py-3">
                    <h3 class="h5 mb-0">Delete Staff Member</h3>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="text-danger mb-3">
                        <i class="fas fa-exclamation-triangle fa-3x"></i>
                    </div>
                    <p class="fs-5">Are you sure you want to delete this staff member?</p>
                    <p class="text-muted">Deleting this staff member will also permanently delete their linked account.</p>
                    
                    <div class="border rounded p-3 mb-4 bg-light text-start">
                        <div class="row mb-2">
                            <div class="col-5 text-muted small">Staff ID:</div>
                            <div class="col-7 fw-bold">#@Model.StaffId</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 text-muted small">Full Name:</div>
                            <div class="col-7 fw-bold">@Model.FirstName @Model.LastName</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 text-muted small">Phone:</div>
                            <div class="col-7">@Model.Phone</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 text-muted small">Email:</div>
                            <div class="col-7">@Model.Email</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-5 text-muted small">Linked Account:</div>
                            <div class="col-7">
                                @if (!string.IsNullOrEmpty(Model.Username))
                                {
                                    <span class="badge bg-light text-dark border">@Model.Username</span>
                                }
                                else
                                {
                                    <span class="text-muted small">None</span>
                                }
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="fas fa-trash-alt me-1"></i> Delete Staff
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
