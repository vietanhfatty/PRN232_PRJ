@model MyProject.Application.DTOs.LabTestDto

@{
    ViewData["Title"] = "Lab Test Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-primary"><i class="fa-solid fa-circle-info me-2"></i>Lab Test Details</h5>
                    @if (!User.IsInRole("Doctor"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.TestId" class="btn btn-outline-warning btn-sm rounded-pill px-3">
                            <i class="fa-solid fa-edit me-1"></i> Edit details
                        </a>
                    }
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold">LAB TEST ID</div>
                        <div class="col-sm-8 text-dark fw-bold">#@Model.TestId</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold">TEST NAME</div>
                        <div class="col-sm-8 text-dark fw-bold fs-5">@Model.TestName</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted small fw-bold">STANDARD COST</div>
                        <div class="col-sm-8 text-dark fw-bold text-success">
                            @Model.Cost.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))
                        </div>
                    </div>

                    <div class="d-flex justify-content-start mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fa-solid fa-arrow-left me-1"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
