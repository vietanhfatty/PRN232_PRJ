@model MyProject.Application.DTOs.UpdatePatientRequest

@{
    ViewData["Title"] = "My Medical Profile";
}

<div class="container mt-4">
    <div class="mb-4">
        <a asp-action="Dashboard" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
            <i class="fa-solid fa-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 bg-white p-4">
                <h3 class="fw-bold text-dark mb-2"><i class="fa-solid fa-user-circle text-info me-2"></i>My Medical Profile</h3>
                <p class="text-muted small border-bottom pb-3 mb-4">View and update your personal coordinates, medical metadata and emergency contacts.</p>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4" role="alert">
                        <div asp-validation-summary="All" class="text-danger small"></div>
                    </div>
                }

                <form asp-action="MyProfile" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Profile Metadata Section -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FullName" class="form-label fw-bold text-muted small">Full Name (Họ và Tên)*</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-signature text-muted"></i></span>
                                <input asp-for="FullName" class="form-control border-start-0 rounded-end-3" required />
                            </div>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Phone" class="form-label fw-bold text-muted small">Phone Number (Số điện thoại)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-phone text-muted"></i></span>
                                <input asp-for="Phone" class="form-control border-start-0 rounded-end-3" />
                            </div>
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="DateOfBirth" class="form-label fw-bold text-muted small">Date of Birth</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-calendar text-muted"></i></span>
                                <input asp-for="DateOfBirth" type="date" class="form-control border-start-0 rounded-end-3" />
                            </div>
                            <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="Gender" class="form-label fw-bold text-muted small">Gender</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-venus-mars text-muted"></i></span>
                                <select asp-for="Gender" class="form-select border-start-0 rounded-end-3">
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                            <span asp-validation-for="Gender" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label asp-for="BloodType" class="form-label fw-bold text-muted small">Blood Type</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-droplet text-danger"></i></span>
                                <select asp-for="BloodType" class="form-select border-start-0 rounded-end-3">
                                    <option value="">Unknown</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                </select>
                            </div>
                            <span asp-validation-for="BloodType" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-bold text-muted small">Address (Địa chỉ thường trú)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-location-dot text-muted"></i></span>
                            <input asp-for="Address" class="form-control border-start-0 rounded-end-3" />
                        </div>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <!-- Emergency Contacts -->
                    <div class="bg-light rounded-4 p-3 mb-4">
                        <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-phone-volume text-danger me-2"></i>Emergency Contact</h6>
                        <div class="row">
                            <div class="col-md-6 mb-2">
                                <label asp-for="EmergencyContactName" class="form-label fw-bold text-muted small">Contact Name</label>
                                <div class="input-group bg-white">
                                    <span class="input-group-text bg-transparent border-end-0"><i class="fa-solid fa-user-shield text-muted"></i></span>
                                    <input asp-for="EmergencyContactName" class="form-control border-start-0 rounded-end-3" />
                                </div>
                                <span asp-validation-for="EmergencyContactName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-2">
                                <label asp-for="EmergencyContactPhone" class="form-label fw-bold text-muted small">Contact Phone</label>
                                <div class="input-group bg-white">
                                    <span class="input-group-text bg-transparent border-end-0"><i class="fa-solid fa-phone text-muted"></i></span>
                                    <input asp-for="EmergencyContactPhone" class="form-control border-start-0 rounded-end-3" />
                                </div>
                                <span asp-validation-for="EmergencyContactPhone" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-info rounded-pill py-2 fw-bold text-white">
                            Update Profile <i class="fa-solid fa-user-check ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
