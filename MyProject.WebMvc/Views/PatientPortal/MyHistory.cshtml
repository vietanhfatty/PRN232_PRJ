@model IEnumerable<MyProject.Application.DTOs.AppointmentDto>

@{
    ViewData["Title"] = "My Appointment History";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800"><i class="fa-solid fa-history text-primary me-2"></i>My Appointment History</h1>
            <p class="text-muted small mb-0">Overview of all past and upcoming consultation requests.</p>
        </div>
        <div>
            <a asp-action="BookAppointment" class="btn btn-success rounded-pill px-4">
                <i class="fa-solid fa-plus me-1"></i> Book Appointment
            </a>
        </div>
    </div>

    <!-- History list -->
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white py-3">
            <h6 class="m-0 fw-bold text-primary">All Bookings (@Model.Count() records)</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase font-monospace fs-7">
                        <tr>
                            <th class="ps-4">Booking ID</th>
                            <th>Doctor</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-calendar-times fa-3x mb-3 text-secondary"></i>
                                    <p class="mb-0 fw-bold">No booking history available.</p>
                                </td>
                            </tr>
                        }
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@app.AppointmentId</td>
                                <td class="fw-bold text-dark">@app.DoctorName</td>
                                <td>@app.AppointmentDate.ToString("yyyy-MM-dd")</td>
                                <td>@app.AppointmentTime.ToString(@"hh\:mm")</td>
                                <td>
                                    @if (app.Status == "Pending")
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-2">Pending</span>
                                    }
                                    else if (app.Status == "Confirmed")
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill px-2">Confirmed</span>
                                    }
                                    else if (app.Status == "InProgress")
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-2">In Progress</span>
                                    }
                                    else if (app.Status == "Completed")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-2">@app.Status</span>
                                    }
                                </td>
                                <td class="text-muted small">@(string.IsNullOrEmpty(app.Reason) ? "-" : app.Reason)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
