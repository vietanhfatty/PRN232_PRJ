@model IEnumerable<MyProject.Application.DTOs.DoctorScheduleDto>
@using MyProject.Application.DTOs

@{
    ViewData["Title"] = "Weekly Shift Roster";

    var today = DateTime.Today;
    var currentDayOfWeek = (int)today.DayOfWeek;
    var daysToMonday = currentDayOfWeek == 0 ? -6 : 1 - currentDayOfWeek;
    var monday = today.AddDays(daysToMonday);
    var weekDates = Enumerable.Range(0, 7).Select(i => monday.AddDays(i)).ToList();
    var weekDaysName = new[] { "MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN" };
    var shifts = new[]
    {
        new { Name = "Morning", Hours = "06:00 - 14:00", Icon = "fa-sun text-warning" },
        new { Name = "Afternoon", Hours = "14:00 - 22:00", Icon = "fa-cloud-sun text-info" },
        new { Name = "Night", Hours = "22:00 - 06:00", Icon = "fa-moon text-dark" }
    };
    var doctors = ViewBag.Doctors as IEnumerable<StaffDto> ?? Enumerable.Empty<StaffDto>();

    // Doctor restriction
    var isDoctor = User.IsInRole("Doctor");
    var currentDoctorId = ViewBag.CurrentDoctorId as int?;
    var currentDoctorInfo = isDoctor
        ? doctors.FirstOrDefault(d => d.StaffId == currentDoctorId)
        : null;
    var currentDoctorName = currentDoctorInfo != null
        ? $"{currentDoctorInfo.FirstName} {currentDoctorInfo.LastName} ({(string.IsNullOrEmpty(currentDoctorInfo.Specialization) ? "Doctor" : currentDoctorInfo.Specialization)})"
        : "(Unknown)";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-slate-800 fw-bold">Weekly Shift Roster</h1>
            <p class="text-muted small mb-0">@monday.ToString("MMMM dd") - @monday.AddDays(6).ToString("MMMM dd, yyyy") • ASM 1 Hospital Roster</p>
        </div>
        <button type="button" class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createScheduleModal">
            <i class="fa-solid fa-plus"></i> Assign Shift
        </button>
    </div>

    <!-- Layout Grid -->
    <div class="dashboard-grid" style="grid-template-columns: 3fr 1fr;">
        <!-- Roster Calendar Panel -->
        <div class="modern-card" style="padding: 24px; overflow-x: auto;">
            <!-- Roster Table/Grid -->
            <div class="shift-grid" style="min-width: 800px;">
                <div class="d-flex align-items-center justify-content-center fw-bold text-slate-400" style="font-size: 10px;">SHIFTS</div>
                @for (int i = 0; i < 7; i++)
                {
                    var date = weekDates[i];
                    var isToday = date.Date == today.Date;
                    <div class="shift-grid-header @(isToday ? "active-day" : "")">
                        <div style="font-size: 11px; font-weight: 700;">@weekDaysName[i]</div>
                        <div style="font-size: 18px; font-weight: 800; line-height: 1.2;">@date.Day</div>
                    </div>
                }

                @foreach (var shift in shifts)
                {
                    <div class="shift-time-label">
                        <div class="d-flex flex-column align-items-center">
                            <i class="fa-solid @shift.Icon mb-1" style="font-size: 16px;"></i>
                            <span class="fw-bold" style="font-size: 11px;">@shift.Name</span>
                            <span class="text-muted" style="font-size: 8px;">@shift.Hours</span>
                        </div>
                    </div>

                    @for (int i = 0; i < 7; i++)
                    {
                        var currentDate = weekDates[i];
                        var cellSchedules = Model.Where(s => s.WorkDate == DateOnly.FromDateTime(currentDate) && s.ShiftName == shift.Name).ToList();

                        <div class="shift-grid-cell">
                            @if (cellSchedules.Any())
                            {
                                @foreach (var sched in cellSchedules)
                                {
                                        <div class="shift-card position-relative" style="@(shift.Name == "Night" ? "background-color: var(--slate-800); border-left-color: var(--slate-900); color: #ffffff;" : "")">
                                            <div class="shift-card-doctor">@sched.DoctorName</div>
                                            <div class="shift-card-dept">Max: @sched.MaxPatients</div>
                                            <div class="d-flex gap-1 mt-1">
                                                @{
                                                    // Doctor chỉ thấy nút edit của shift mình
                                                    var canEdit = !isDoctor || sched.DoctorId == currentDoctorId;
                                                }
                                                @if (canEdit)
                                                {
                                                    <button type="button" class="btn btn-xs px-1 py-0"
                                                            style="font-size: 9px; background: rgba(255,193,7,0.2); color: #856404; border: none;"
                                                            onclick="openEditScheduleModal(@sched.ScheduleId, @sched.DoctorId, '@sched.WorkDate.ToString("yyyy-MM-dd")', '@sched.ShiftName', @sched.MaxPatients)">
                                                        <i class="fa-solid fa-pen"></i>
                                                    </button>
                                                }
                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <button type="button" class="btn btn-xs px-1 py-0"
                                                            style="font-size: 9px; background: rgba(220,53,69,0.2); color: #842029; border: none;"
                                                            onclick="openDeleteScheduleModal(@sched.ScheduleId, '@sched.DoctorName')">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                }
                            }
                            else
                            {
                                <button type="button" class="shift-card-available"
                                        onclick="openCreateScheduleWithDefaults('@currentDate.ToString("yyyy-MM-dd")', '@shift.Name')">
                                    <i class="fa-solid fa-plus me-1" style="font-size: 10px;"></i> Add
                                </button>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Right Side Panel -->
        <div>
            <div class="modern-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold text-slate-800 mb-0">Coverage Status</h6>
                    <span class="text-success small fw-bold">84%</span>
                </div>
                <div class="occupancy-progress mb-3">
                    <div class="progress-fill fill-green" style="width: 84%;"></div>
                </div>
            </div>

            <div class="modern-card">
                <h6 class="fw-bold text-slate-800 mb-3">Available Staff</h6>
                <div class="d-flex flex-column gap-3">
                    @foreach (var doc in doctors.Take(3))
                    {
                        var di = (!string.IsNullOrEmpty(doc.FirstName) ? doc.FirstName[0].ToString() : "") +
                                 (!string.IsNullOrEmpty(doc.LastName) ? doc.LastName[0].ToString() : "");
                        var avatarColors = new[] { "avatar-blue", "avatar-indigo", "avatar-purple" };
                        var ac = avatarColors[Math.Abs(doc.StaffId) % avatarColors.Length];
                        <div class="d-flex align-items-center justify-content-between pb-2 border-bottom">
                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar-circle @ac" style="width: 32px; height: 32px; font-size: 11px;">@di.ToUpper()</div>
                                <div class="d-flex flex-column">
                                    <span class="fw-bold text-slate-800" style="font-size: 13px;">@doc.FirstName @doc.LastName</span>
                                    <span class="text-muted" style="font-size: 10px;">@(string.IsNullOrEmpty(doc.Specialization) ? "Doctor" : doc.Specialization)</span>
                                </div>
                            </div>
                            <span class="badge bg-success-subtle text-success border border-success-subtle" style="font-size: 9px; font-weight: 700;">Available</span>
                        </div>
                    }
                </div>
                <div class="text-center mt-3 pt-2 border-top">
                    <a asp-controller="Staffs" asp-action="Index" class="fw-bold text-decoration-none" style="font-size: 12px; color: var(--primary);">View All Staff</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Schedule Modal -->
<div class="modal fade" id="createScheduleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-calendar-plus me-2"></i>Register Work Shift</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Select Doctor</label>
                        @if (isDoctor)
                        {
                            <input type="hidden" name="DoctorId" value="@currentDoctorId" />
                            <input type="text" class="form-control rounded-3" value="@currentDoctorName" disabled />
                        }
                        else
                        {
                            <select name="DoctorId" id="createScheduleDoctorId" class="form-select rounded-3" required>
                                <option value="">-- Select Doctor --</option>
                                @foreach (var doc in doctors)
                                {
                                    <option value="@doc.StaffId">@doc.FirstName @doc.LastName (@(string.IsNullOrEmpty(doc.Specialization) ? "Doctor" : doc.Specialization))</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Work Date</label>
                        <input type="date" name="WorkDate" id="createScheduleWorkDate" class="form-control rounded-3" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Shift Name</label>
                        <select name="ShiftName" id="createScheduleShift" class="form-select rounded-3" required>
                            <option value="">-- Select Shift --</option>
                            <option value="Morning">Morning</option>
                            <option value="Afternoon">Afternoon</option>
                            <option value="Night">Night</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Max Patients Limit</label>
                        <input type="number" name="MaxPatients" min="1" max="100" class="form-control rounded-3" value="20" required />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="fa-solid fa-save me-1"></i> Register Shift
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Schedule Modal -->
<div class="modal fade" id="editScheduleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-warning text-dark rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-calendar-check me-2"></i>Edit Work Shift</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editScheduleForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Select Doctor</label>
                        @if (isDoctor)
                        {
                            <input type="hidden" name="DoctorId" id="editScheduleDoctorId" />
                            <input type="text" id="editScheduleDoctorDisplay" class="form-control rounded-3" value="@currentDoctorName" disabled />
                        }
                        else
                        {
                            <select name="DoctorId" id="editScheduleDoctorId" class="form-select rounded-3" required>
                                @foreach (var doc in doctors)
                                {
                                    <option value="@doc.StaffId">@doc.FirstName @doc.LastName (@(string.IsNullOrEmpty(doc.Specialization) ? "Doctor" : doc.Specialization))</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Work Date</label>
                        <input type="date" name="WorkDate" id="editScheduleWorkDate" class="form-control rounded-3" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Shift Name</label>
                        <select name="ShiftName" id="editScheduleShift" class="form-select rounded-3" required>
                            <option value="Morning">Morning</option>
                            <option value="Afternoon">Afternoon</option>
                            <option value="Night">Night</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Max Patients Limit</label>
                        <input type="number" name="MaxPatients" id="editScheduleMaxPatients" min="1" max="100" class="form-control rounded-3" required />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">
                        <i class="fa-solid fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteScheduleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-trash-alt me-2"></i>Delete Shift</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <i class="fa-solid fa-exclamation-triangle fa-3x text-danger mb-3"></i>
                <p class="mb-1">Delete shift for:</p>
                <p class="fw-bold fs-6" id="deleteScheduleName"></p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteScheduleForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        <i class="fa-solid fa-trash-alt me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCreateScheduleWithDefaults(workDate, shiftName) {
            document.getElementById('createScheduleWorkDate').value = workDate;
            document.getElementById('createScheduleShift').value = shiftName;
            new bootstrap.Modal(document.getElementById('createScheduleModal')).show();
        }

        function openEditScheduleModal(id, doctorId, workDate, shiftName, maxPatients) {
            document.getElementById('editScheduleDoctorId').value = doctorId;
            document.getElementById('editScheduleWorkDate').value = workDate;
            document.getElementById('editScheduleShift').value = shiftName;
            document.getElementById('editScheduleMaxPatients').value = maxPatients;
            document.getElementById('editScheduleForm').action = '/DoctorSchedules/Edit/' + id;
            new bootstrap.Modal(document.getElementById('editScheduleModal')).show();
        }

        function openDeleteScheduleModal(id, doctorName) {
            document.getElementById('deleteScheduleName').textContent = doctorName;
            document.getElementById('deleteScheduleForm').action = '/DoctorSchedules/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteScheduleModal')).show();
        }
    </script>
}
