@model IEnumerable<MyProject.Application.DTOs.AppointmentDto>

@{
    ViewData["Title"] = "My Patient Waiting Queue";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800"><i class="fa-solid fa-people-queue text-success me-2"></i>My Waiting Queue</h1>
            <p class="text-muted small mb-0">Active queue for Doctor: <strong>@ViewBag.DoctorName</strong> (Today's Waiting Patients)</p>
        </div>

    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-white py-3">
            <h6 class="m-0 fw-bold text-success">Patients Waiting (@Model.Count())</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase font-monospace fs-7">
                        <tr>
                            <th class="ps-4">Queue Number</th>
                            <th>Patient Name</th>
                            <th>Appointment Time</th>
                            <th>Type</th>
                            <th>Reason for Visit</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-mug-hot fa-3x mb-3 text-success"></i>
                                    <p class="mb-0 fw-bold">No patients waiting in queue!</p>
                                    <p class="small text-muted mb-0">Either all patients have been treated or none have checked in today.</p>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="badge bg-success rounded-pill px-3 py-2 fs-6">Q-@item.QueueNumber</span>
                                </td>
                                <td class="fw-bold text-dark">@item.PatientName</td>
                                <td>@item.AppointmentDate.ToString("HH:mm")</td>
                                <td>
                                    @if (item.Type == "First Visit")
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill px-2">First Visit</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border rounded-pill px-2">Follow-up</span>
                                    }
                                </td>
                                <td>@(string.IsNullOrEmpty(item.Reason) ? "General Checkup" : item.Reason)</td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-info rounded-pill px-3">
                                        <i class="fa-solid fa-address-book me-1"></i> Patient Record
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
