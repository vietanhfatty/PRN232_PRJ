@model IEnumerable<MyProject.Application.DTOs.AppointmentDto>
@using MyProject.Application.DTOs

@{
    ViewData["Title"] = "Appointments Registry";
    var patients = ViewBag.Patients as IEnumerable<PatientDto> ?? Enumerable.Empty<PatientDto>();
    var doctors = ViewBag.Doctors as IEnumerable<DoctorDto> ?? Enumerable.Empty<DoctorDto>();
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Appointments Registry</h1>
            <p class="text-muted small mb-0">Record and manage patient appointments and check-in queues</p>
        </div>
        <div>
            @if (User.IsInRole("Doctor"))
            {
                <a asp-action="Queue" class="btn btn-success shadow-sm rounded-pill px-4 me-2">
                    <i class="fa-solid fa-people-queue me-1"></i> My Waiting Queue
                </a>
            }
            <button type="button" class="btn btn-primary shadow-sm rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#createAppointmentModal">
                <i class="fa-solid fa-plus-circle me-1"></i> Book Appointment
            </button>
        </div>
    </div>

    <!-- Advanced filters bar -->
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="row g-3 align-items-end">
                <!-- Patient Name search -->
                <div class="col-md-3">
                    <label for="patientSearchInput" class="form-label fw-bold small text-muted">Search Patient</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fa-solid fa-user text-muted"></i>
                        </span>
                        <input type="text" id="patientSearchInput" class="form-control border-start-0 rounded-end-3" placeholder="Search patient name..." />
                    </div>
                </div>

                <!-- Doctor select dropdown -->
                <div class="col-md-3">
                    <label for="doctorFilterSelect" class="form-label fw-bold small text-muted">Filter Doctor</label>
                    <select id="doctorFilterSelect" class="form-select rounded-3">
                        <option value="">All Doctors</option>
                        @foreach (var doc in doctors)
                        {
                            <option value="@doc.DoctorId">@doc.FullName (@(string.IsNullOrEmpty(doc.Specialization) ? "General" : doc.Specialization))</option>
                        }
                    </select>
                </div>

                <!-- Date Picker -->
                <div class="col-md-3">
                    <label for="dateFilterInput" class="form-label fw-bold small text-muted">Filter Date</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fa-solid fa-calendar text-muted"></i>
                        </span>
                        <input type="date" id="dateFilterInput" class="form-control border-start-0 rounded-end-3" />
                    </div>
                </div>

                <!-- Quick Date Filters -->
                <div class="col-md-3">
                    <label class="form-label fw-bold small text-muted d-block">Quick Date Filters</label>
                    <div class="btn-group w-100" role="group">
                        <button type="button" id="btnFilterToday" class="btn btn-outline-primary px-2 py-2 text-nowrap">Today</button>
                        <button type="button" id="btnFilterTomorrow" class="btn btn-outline-primary px-2 py-2 text-nowrap">Tomorrow</button>
                        <button type="button" id="btnFilterThisWeek" class="btn btn-outline-primary px-2 py-2 text-nowrap">This Week</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-white py-3">
            <h6 class="m-0 fw-bold text-primary">Appointment Bookings (@Model.Count() records)</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="appointmentTable">
                    <thead class="table-light text-uppercase font-monospace fs-7">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Patient Name</th>
                            <th>Doctor Name</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var safeReason = (item.Reason ?? "").Replace("'", "\\'").Replace("\n", " ").Replace("\r", "");
                            var apptDateStr = item.AppointmentDate.ToString("yyyy-MM-dd");
                            var apptTimeStr = item.AppointmentTime.ToString(@"hh\:mm");

                            <tr class="appt-row" data-doctor-id="@item.DoctorId" data-date="@item.AppointmentDate.ToString("yyyy-MM-dd")">
                                <td class="ps-4 fw-bold text-secondary">#@item.AppointmentId</td>
                                <td class="fw-bold text-dark appt-patient">@item.PatientName</td>
                                <td class="appt-doctor">@item.DoctorName</td>
                                <td>@item.AppointmentDate.ToString("yyyy-MM-dd")</td>
                                <td>@apptTimeStr</td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-2">Pending</span>
                                    }
                                    else if (item.Status == "Confirmed")
                                    {
                                        <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill px-2">Confirmed</span>
                                    }
                                    else if (item.Status == "Completed")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-2">Cancelled</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (item.Status == "Pending")
                                    {
                                        <form asp-action="CheckIn" asp-route-id="@item.AppointmentId" method="post" class="d-inline-block me-1">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill px-3">
                                                <i class="fa-solid fa-clipboard-check me-1"></i>Confirm
                                            </button>
                                        </form>
                                    }
                                    <button type="button" class="btn btn-sm btn-outline-warning rounded-pill px-3 me-1"
                                            onclick="openEditAppointmentModal(@item.AppointmentId, @item.PatientId, @item.DoctorId, '@apptDateStr', '@apptTimeStr', '@item.Status', '@safeReason')">
                                        <i class="fa-solid fa-edit"></i>
                                    </button>
                                    <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-sm btn-outline-info rounded-pill px-3 me-1">
                                        <i class="fa-solid fa-info-circle"></i>
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                                onclick="openDeleteAppointmentModal(@item.AppointmentId, '@item.PatientName'.replace(/'/g, ''))">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create Appointment Modal -->
<div class="modal fade" id="createAppointmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-calendar-plus me-2"></i>Book New Appointment</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Select Patient</label>
                            <select name="PatientId" class="form-select rounded-3" required>
                                <option value="">-- Select Patient --</option>
                                @foreach (var pat in patients)
                                {
                                    <option value="@pat.PatientId">@pat.FullName (@(pat.Phone ?? "N/A"))</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Select Doctor</label>
                            <select name="DoctorId" class="form-select rounded-3" required>
                                <option value="">-- Select Doctor --</option>
                                @foreach (var doc in doctors)
                                {
                                    <option value="@doc.DoctorId">@doc.FullName (@(string.IsNullOrEmpty(doc.Specialization) ? "General" : doc.Specialization))</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Appointment Date</label>
                            <input type="date" name="AppointmentDate" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Appointment Time</label>
                            <input type="time" name="AppointmentTime" class="form-control rounded-3" required />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold small text-muted">Reason for Visit</label>
                        <textarea name="Reason" rows="2" class="form-control rounded-3" placeholder="Enter reason for booking..."></textarea>
                    </div>
                    <input type="hidden" name="Status" value="Pending" />
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="fa-solid fa-calendar-check me-1"></i> Book Appointment
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Appointment Modal -->
<div class="modal fade" id="editAppointmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-warning text-dark rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-edit me-2"></i>Modify Appointment Booking</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editAppointmentForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Select Patient</label>
                            <select name="PatientId" id="editApptPatientId" class="form-select rounded-3" required>
                                @foreach (var pat in patients)
                                {
                                    <option value="@pat.PatientId">@pat.FullName (@(pat.Phone ?? "N/A"))</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Select Doctor</label>
                            <select name="DoctorId" id="editApptDoctorId" class="form-select rounded-3" required>
                                @foreach (var doc in doctors)
                                {
                                    <option value="@doc.DoctorId">@doc.FullName (@(string.IsNullOrEmpty(doc.Specialization) ? "General" : doc.Specialization))</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Appointment Date</label>
                            <input type="date" name="AppointmentDate" id="editApptDate" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Appointment Time</label>
                            <input type="time" name="AppointmentTime" id="editApptTime" class="form-control rounded-3" required />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold small text-muted">Status</label>
                            <select name="Status" id="editApptStatus" class="form-select rounded-3">
                                <option value="Pending">Pending</option>
                                <option value="Confirmed">Confirmed</option>
                                <option value="Completed">Completed</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold small text-muted">Reason for Visit</label>
                        <textarea name="Reason" id="editApptReason" rows="2" class="form-control rounded-3"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">
                        <i class="fa-solid fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteAppointmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-trash-alt me-2"></i>Delete Appointment</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <i class="fa-solid fa-exclamation-triangle fa-3x text-danger mb-3"></i>
                <p class="mb-1">Delete appointment for:</p>
                <p class="fw-bold fs-6" id="deleteApptPatientName"></p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteAppointmentForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        <i class="fa-solid fa-trash-alt me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const patientInput = document.getElementById('patientSearchInput');
        const doctorSelect = document.getElementById('doctorFilterSelect');
        const dateInput = document.getElementById('dateFilterInput');
        const btnToday = document.getElementById('btnFilterToday');
        const btnTomorrow = document.getElementById('btnFilterTomorrow');
        const btnThisWeek = document.getElementById('btnFilterThisWeek');

        let activeDateMode = 'today'; // 'today', 'tomorrow', 'thisweek', 'custom'

        function getTodayDateString() {
            const now = new Date();
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function getTomorrowDateString() {
            const now = new Date();
            now.setDate(now.getDate() + 1);
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const day = String(now.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        // Initialize default filter to Today
        dateInput.value = getTodayDateString();
        updateQuickButtonStyles();
        applyFilters();

        function updateQuickButtonStyles() {
            btnToday.classList.toggle('active', activeDateMode === 'today');
            btnToday.classList.toggle('btn-primary', activeDateMode === 'today');
            btnToday.classList.toggle('btn-outline-primary', activeDateMode !== 'today');

            btnTomorrow.classList.toggle('active', activeDateMode === 'tomorrow');
            btnTomorrow.classList.toggle('btn-primary', activeDateMode === 'tomorrow');
            btnTomorrow.classList.toggle('btn-outline-primary', activeDateMode !== 'tomorrow');

            btnThisWeek.classList.toggle('active', activeDateMode === 'thisweek');
            btnThisWeek.classList.toggle('btn-primary', activeDateMode === 'thisweek');
            btnThisWeek.classList.toggle('btn-outline-primary', activeDateMode !== 'thisweek');
        }

        function applyFilters() {
            const searchVal = patientInput.value.toLowerCase().trim();
            const doctorVal = doctorSelect.value;
            const dateVal = dateInput.value;

            let weekStart = null;
            let weekEnd = null;
            if (activeDateMode === 'thisweek') {
                const now = new Date();
                const day = now.getDay();
                const diffToMonday = now.getDate() - day + (day === 0 ? -6 : 1);
                weekStart = new Date(now.setDate(diffToMonday));
                weekStart.setHours(0,0,0,0);
                
                weekEnd = new Date(weekStart);
                weekEnd.setDate(weekStart.getDate() + 6);
                weekEnd.setHours(23,59,59,999);
            }

            document.querySelectorAll('.appt-row').forEach(function(row) {
                const patientName = row.querySelector('.appt-patient').textContent.toLowerCase();
                const matchesPatient = patientName.includes(searchVal);

                const rowDoctorId = row.getAttribute('data-doctor-id');
                const matchesDoctor = !doctorVal || rowDoctorId === doctorVal;

                const rowDateStr = row.getAttribute('data-date');
                let matchesDate = false;

                if (activeDateMode === 'thisweek') {
                    const rowDate = new Date(rowDateStr);
                    rowDate.setHours(0,0,0,0);
                    matchesDate = rowDate >= weekStart && rowDate <= weekEnd;
                } else if (dateVal) {
                    matchesDate = rowDateStr === dateVal;
                } else {
                    matchesDate = true;
                }

                if (matchesPatient && matchesDoctor && matchesDate) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        patientInput.addEventListener('keyup', applyFilters);
        doctorSelect.addEventListener('change', applyFilters);
        
        dateInput.addEventListener('change', function() {
            activeDateMode = 'custom';
            updateQuickButtonStyles();
            applyFilters();
        });

        btnToday.addEventListener('click', function() {
            activeDateMode = 'today';
            dateInput.value = getTodayDateString();
            updateQuickButtonStyles();
            applyFilters();
        });

        btnTomorrow.addEventListener('click', function() {
            activeDateMode = 'tomorrow';
            dateInput.value = getTomorrowDateString();
            updateQuickButtonStyles();
            applyFilters();
        });

        btnThisWeek.addEventListener('click', function() {
            activeDateMode = 'thisweek';
            dateInput.value = ''; // Clear picker to show it's a range
            updateQuickButtonStyles();
            applyFilters();
        });

        function openEditAppointmentModal(id, patientId, doctorId, apptDate, apptTime, status, reason) {
            document.getElementById('editApptPatientId').value = patientId;
            document.getElementById('editApptDoctorId').value = doctorId;
            document.getElementById('editApptDate').value = apptDate;
            document.getElementById('editApptTime').value = apptTime;
            document.getElementById('editApptStatus').value = status;
            document.getElementById('editApptReason').value = reason;
            document.getElementById('editAppointmentForm').action = '/Appointments/Edit/' + id;
            new bootstrap.Modal(document.getElementById('editAppointmentModal')).show();
        }

        function openDeleteAppointmentModal(id, patientName) {
            document.getElementById('deleteApptPatientName').textContent = patientName;
            document.getElementById('deleteAppointmentForm').action = '/Appointments/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deleteAppointmentModal')).show();
        }
    </script>
}
