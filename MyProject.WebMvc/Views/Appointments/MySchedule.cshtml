@model IEnumerable<MyProject.Application.DTOs.DoctorScheduleDto>

@{
    ViewData["Title"] = "My Work Schedule";
    var doctorName = ViewBag.DoctorName as string ?? "Doctor";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800"><i class="fa-solid fa-calendar-days text-primary me-2"></i>My Work Schedule</h1>
            <p class="text-muted small mb-0">Manage your duty shifts and block time slots for Dr. @doctorName</p>
        </div>
        <button type="button" class="btn btn-primary shadow-sm rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addShiftModal">
            <i class="fa-solid fa-plus-circle me-1"></i> Add Work Shift
        </button>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary">Active Working Shifts (@Model.Count() shifts)</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-uppercase font-monospace fs-7">
                                <tr>
                                    <th class="ps-4">Date</th>
                                    <th>Day of Week</th>
                                    <th>Shift Name</th>
                                    <th>Max Patients</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <i class="fa-solid fa-calendar-minus fa-3x mb-3 text-secondary"></i>
                                            <p class="mb-0 fw-bold">No active shifts scheduled!</p>
                                            <p class="small text-muted mb-0">Add a work shift to mark yourself as available.</p>
                                        </td>
                                    </tr>
                                }
                                @foreach (var item in Model)
                                {
                                    var dayOfWeek = item.WorkDate.ToDateTime(TimeOnly.MinValue).ToString("dddd");
                                    var badgeColor = "bg-primary text-white";
                                    if (item.ShiftName == "Afternoon") badgeColor = "bg-warning text-dark";
                                    else if (item.ShiftName == "Night") badgeColor = "bg-dark text-white";

                                    <tr>
                                        <td class="ps-4 fw-bold text-dark">@item.WorkDate.ToString("yyyy-MM-dd")</td>
                                        <td>@dayOfWeek</td>
                                        <td>
                                            <span class="badge @badgeColor px-3 py-2 rounded-pill">@item.ShiftName</span>
                                        </td>
                                        <td>@item.MaxPatients</td>
                                        <td class="text-end pe-4">
                                            <form asp-action="DeleteShift" asp-route-id="@item.ScheduleId" method="post" class="d-inline-block">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="return confirm('Block/remove this shift? Receptionists will not be able to book patients for this slot.')">
                                                    <i class="fa-solid fa-ban me-1"></i> Block Slot
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-slate-800">Shift Roster Information</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted small">
                        <strong>Availability:</strong> The system automatically permits patients and receptionists to schedule appointments on dates/shifts where you have active working shifts.
                    </p>
                    <p class="text-muted small">
                        <strong>Blocking slots:</strong> Click "Block Slot" next to any shift to indicate you are unavailable (due to leave, meetings, or conferences). This immediately locks the slot.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Shift Modal -->
<div class="modal fade" id="addShiftModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-calendar-plus me-2"></i>Add Working Shift</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddShift" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Work Date</label>
                        <input type="date" name="workDate" class="form-control rounded-3" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Shift Name</label>
                        <select name="shiftName" class="form-select rounded-3" required>
                            <option value="Morning">Morning</option>
                            <option value="Afternoon">Afternoon</option>
                            <option value="Night">Night</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="fa-solid fa-plus me-1"></i> Add Shift
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
