@model MyProject.Application.DTOs.UpdateAppointmentRequest

@{
    ViewData["Title"] = "Modify Appointment Booking";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0 fw-bold text-primary"><i class="fa-solid fa-edit me-2"></i>Modify Appointment Booking</h5>
                </div>
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            <div asp-validation-summary="All" class="text-danger small"></div>
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="PatientId" class="form-label fw-bold small text-muted">Select Patient</label>
                                <select asp-for="PatientId" class="form-select rounded-3" required>
                                    @if (ViewBag.Patients != null)
                                    {
                                        @foreach (var pat in ViewBag.Patients)
                                        {
                                            <option value="@pat.PatientId" selected="@(Model.PatientId == pat.PatientId)">@pat.FirstName @pat.LastName (@pat.Phone)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DoctorId" class="form-label fw-bold small text-muted">Select Doctor</label>
                                <select asp-for="DoctorId" class="form-select rounded-3" required>
                                    @if (ViewBag.Doctors != null)
                                    {
                                        @foreach (var doc in ViewBag.Doctors)
                                        {
                                            <option value="@doc.StaffId" selected="@(Model.DoctorId == doc.StaffId)">@doc.FirstName @doc.LastName (@(string.IsNullOrEmpty(doc.Specialization) ? "General" : doc.Specialization))</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="AppointmentDate" class="form-label fw-bold small text-muted">Appointment Date & Time</label>
                                <input asp-for="AppointmentDate" type="datetime-local" class="form-control rounded-3" required value="@Model.AppointmentDate.ToString("yyyy-MM-ddTHH:mm")" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label fw-bold small text-muted">Appointment Type</label>
                                <select asp-for="Type" class="form-select rounded-3">
                                    <option value="First Visit" selected="@(Model.Type == "First Visit")">First Visit</option>
                                    <option value="Follow-up" selected="@(Model.Type == "Follow-up")">Follow-up</option>
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label fw-bold small text-muted">Status</label>
                                <select asp-for="Status" class="form-select rounded-3">
                                    <option value="Scheduled" selected="@(Model.Status == "Scheduled")">Scheduled</option>
                                    <option value="Waiting" selected="@(Model.Status == "Waiting")">Waiting</option>
                                    <option value="Completed" selected="@(Model.Status == "Completed")">Completed</option>
                                    <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Cancelled</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="QueueNumber" class="form-label fw-bold small text-muted">Queue Number</label>
                                <input asp-for="QueueNumber" type="number" class="form-control rounded-3" placeholder="e.g. 5 (leave blank if none)" value="@Model.QueueNumber" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Reason" class="form-label fw-bold small text-muted">Reason for Visit</label>
                            <textarea asp-for="Reason" rows="3" class="form-control rounded-3">@Model.Reason</textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
