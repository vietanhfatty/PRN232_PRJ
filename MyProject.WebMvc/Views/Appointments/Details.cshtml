@model MyProject.Application.DTOs.AppointmentDto

@{
    ViewData["Title"] = "Appointment Booking Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-primary"><i class="fa-solid fa-circle-info me-2"></i>Appointment Details</h5>
                    <a asp-action="Edit" asp-route-id="@Model.AppointmentId" class="btn btn-outline-warning btn-sm rounded-pill px-3">
                        <i class="fa-solid fa-edit me-1"></i> Edit details
                    </a>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold">APPOINTMENT ID</div>
                        <div class="col-sm-8 text-dark fw-bold">#@Model.AppointmentId</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold">PATIENT NAME</div>
                        <div class="col-sm-8 text-dark fw-bold fs-5">@Model.PatientName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold">ASSIGNED DOCTOR</div>
                        <div class="col-sm-8 text-dark">@Model.DoctorName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold">DATE & TIME</div>
                        <div class="col-sm-8 text-dark">@Model.AppointmentDate.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold">QUEUE NUMBER</div>
                        <div class="col-sm-8 text-dark">
                            @if (Model.QueueNumber.HasValue)
                            {
                                <span class="badge bg-primary rounded-pill px-3 py-1">Q-@Model.QueueNumber</span>
                            }
                            else
                            {
                                <span class="text-muted small">Not checked-in yet</span>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold">TYPE</div>
                        <div class="col-sm-8">
                            <span class="badge bg-secondary-subtle text-secondary border rounded-pill px-3 py-1">@Model.Type</span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold">STATUS</div>
                        <div class="col-sm-8">
                            @if (Model.Status == "Scheduled")
                            {
                                <span class="badge bg-warning-subtle text-warning border rounded-pill px-3 py-1">Scheduled</span>
                            }
                            else if (Model.Status == "Waiting")
                            {
                                <span class="badge bg-info-subtle text-info border rounded-pill px-3 py-1">Waiting</span>
                            }
                            else if (Model.Status == "Completed")
                            {
                                <span class="badge bg-success-subtle text-success border rounded-pill px-3 py-1">Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border rounded-pill px-3 py-1">Cancelled</span>
                            }
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted small fw-bold">REASON FOR BOOKING</div>
                        <div class="col-sm-8 text-dark text-wrap">@(string.IsNullOrEmpty(Model.Reason) ? "No details provided" : Model.Reason)</div>
                    </div>

                    <div class="d-flex justify-content-start mt-4 gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fa-solid fa-arrow-left me-1"></i> Back to List
                        </a>
                        @if (User.IsInRole("Doctor"))
                        {
                            <button type="button" class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#followupModal">
                                <i class="fa-solid fa-calendar-plus me-1"></i> Schedule Follow-up
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("Doctor"))
{
    <!-- Follow-up Booking Modal -->
    <div class="modal fade" id="followupModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header bg-primary text-white rounded-top-4">
                    <h5 class="modal-title"><i class="fa-solid fa-clock me-2"></i>Schedule Follow-up Appointment</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="ScheduleFollowup" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="patientId" value="@Model.PatientId" />
                    <div class="modal-body p-4">
                        <div class="alert alert-info rounded-3 small">
                            <i class="fa-solid fa-circle-info me-2"></i>You are scheduling a follow-up appointment for patient: <strong>@Model.PatientName</strong>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">Select Appointment Date & Time</label>
                            <input type="datetime-local" name="appointmentDate" class="form-control rounded-3" required 
                                   value="@DateTime.Today.AddDays(14).ToString("yyyy-MM-ddT09:00")" />
                            <small class="text-muted">Tip: Follow-up is usually recommended in 14 days.</small>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">Follow-up Reason / Notes</label>
                            <textarea name="reason" class="form-control rounded-3" rows="3" placeholder="Enter specific instructions or reason for follow-up..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4">
                            <i class="fa-solid fa-calendar-check me-1"></i> Confirm Follow-up
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
