@model IEnumerable<MyProject.Application.DTOs.PatientDto>

@{
    ViewData["Title"] = "Patient Management";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-slate-800 fw-bold">Patient Management</h1>
            <p class="text-muted small mb-0">Search, register, and manage hospital admissions.</p>
        </div>
        <button type="button" class="btn-primary-custom" data-bs-toggle="modal" data-bs-target="#createPatientModal">
            <i class="fa-solid fa-user-plus"></i> New Registration
        </button>
    </div>

    <!-- Advanced Search Panel -->
    <div class="modern-card" style="padding: 20px;">
        <h6 class="fw-bold text-slate-700 mb-3"><i class="fa-solid fa-sliders me-2"></i>Advanced Search</h6>
        <form method="get" asp-action="Index">
            <div class="search-card-filters">
                <div class="form-group-custom">
                    <label class="form-label-custom">Patient Name</label>
                    <input type="text" name="searchName" value="@ViewBag.SearchName" class="form-control-custom" placeholder="e.g. John Doe" />
                </div>
                <div class="form-group-custom">
                    <label class="form-label-custom">Phone Number</label>
                    <input type="text" name="searchPhone" value="@ViewBag.SearchPhone" class="form-control-custom" placeholder="+1 (555) 000-0000" />
                </div>
                <div class="form-group-custom">
                    <label class="form-label-custom">Insurance ID</label>
                    <input type="text" name="searchInsurance" value="@ViewBag.SearchInsurance" class="form-control-custom" placeholder="INS-12345678" />
                </div>
                <div class="form-group-custom" style="flex: 0 0 150px;">
                    <label class="form-label-custom">Gender</label>
                    <select name="filterGender" class="form-control-custom" style="padding: 9px 12px;">
                        <option value="All">All Genders</option>
                        <option value="Male" selected="@(ViewBag.FilterGender == "Male")">Male</option>
                        <option value="Female" selected="@(ViewBag.FilterGender == "Female")">Female</option>
                        <option value="Other" selected="@(ViewBag.FilterGender == "Other")">Other</option>
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom" style="padding: 10px 18px;">
                        <i class="fa-solid fa-magnifying-glass"></i> Search
                    </button>
                    <a asp-action="Index" class="btn-secondary-custom" style="padding: 10px 18px;">Reset</a>
                </div>
            </div>
        </form>

        <!-- Quick Filters -->
        <div class="d-flex align-items-center gap-3 pt-2 border-top">
            <span class="text-muted small fw-bold text-uppercase" style="letter-spacing: 0.5px; font-size: 11px;">Quick Filters:</span>
            <div class="d-flex gap-2">
                <a href="?filterGender=Female" class="btn-pill-filter @(ViewBag.FilterGender == "Female" ? "active" : "")">Gender: Female</a>
                <a href="?filterGender=Male" class="btn-pill-filter @(ViewBag.FilterGender == "Male" ? "active" : "")">Gender: Male</a>
            </div>
        </div>
    </div>

    <!-- Patients List Table -->
    <div class="modern-card modern-table-card">
        <div class="modern-table-header">
            <h5 class="modern-table-title">Registered Patients (@Model.Count())</h5>
        </div>
        <div class="table-responsive">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th style="width: 250px;">Patient Name</th>
                        <th>DOB / Age</th>
                        <th>Insurance No.</th>
                        <th>Status</th>
                        <th class="text-end" style="width: 280px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-users-slash fa-2x mb-3 text-secondary"></i>
                                <p class="mb-0">No patients matched the criteria.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            var initials = "PT";
                            if (!string.IsNullOrEmpty(item.FirstName))
                            {
                                initials = (item.FirstName[0].ToString() + (item.LastName.Length > 0 ? item.LastName[0].ToString() : "")).ToUpper();
                            }
                            var age = DateTime.Today.Year - item.Dob.Year;
                            if (item.Dob > DateOnly.FromDateTime(DateTime.Today.AddYears(-age))) age--;

                            var todayAppts = ViewBag.TodayAppointments as IEnumerable<MyProject.Application.DTOs.AppointmentDto> ?? Enumerable.Empty<MyProject.Application.DTOs.AppointmentDto>();
                            var patientAppt = todayAppts.FirstOrDefault(a => a.PatientId == item.PatientId);
                            
                            var status = "Active";
                            if (patientAppt != null)
                            {
                                status = patientAppt.Status;
                            }

                            var avatarClasses = new[] { "avatar-blue", "avatar-indigo", "avatar-purple", "avatar-pink", "avatar-emerald", "avatar-rose" };
                            var avatarClass = avatarClasses[Math.Abs(item.PatientId) % avatarClasses.Length];

                            // Escape for JS
                            var safeFirst = item.FirstName.Replace("'", "\\'").Replace("\"", "&quot;");
                            var safeLast = item.LastName.Replace("'", "\\'").Replace("\"", "&quot;");
                            var safePhone = item.Phone.Replace("'", "\\'");
                            var safeInsurance = (item.InsuranceNo ?? "").Replace("'", "\\'");
                            var safeAddress = (item.Address ?? "").Replace("'", "\\'").Replace("\n", " ").Replace("\r", "");
                            var dobStr = item.Dob.ToString("yyyy-MM-dd");

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-circle @avatarClass">@initials</div>
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-slate-800">@item.FirstName @item.LastName</span>
                                            <span class="text-muted" style="font-size: 11px;">@item.Phone</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-medium">@item.Dob.ToString("dd MMM yyyy")</span>
                                    <span class="text-muted small">(@(age)y)</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.InsuranceNo))
                                    {
                                        <span class="font-monospace text-slate-600">@item.InsuranceNo</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (status == "Waiting")
                                    {
                                        <span class="modern-badge badge-waiting">Waiting</span>
                                    }
                                    else if (status == "Scheduled")
                                    {
                                        <span class="modern-badge badge-scheduled">Scheduled</span>
                                    }
                                    else if (status == "Completed")
                                    {
                                        <span class="modern-badge badge-active">Completed</span>
                                    }
                                    else if (status == "Cancelled")
                                    {
                                        <span class="modern-badge bg-danger-subtle text-danger border border-danger-subtle">Cancelled</span>
                                    }
                                    else
                                    {
                                        <span class="modern-badge badge-active">Active</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        @if (status == "Waiting")
                                        {
                                            <button class="btn btn-sm btn-light border rounded-pill px-3 py-1 fw-bold text-muted small" style="font-size: 12px;" disabled>
                                                <i class="fa-solid fa-check me-1"></i> In Queue
                                            </button>
                                        }
                                        else if (status == "Scheduled" && patientAppt != null)
                                        {
                                            <form asp-controller="Appointments" asp-action="CheckIn" asp-route-id="@patientAppt.AppointmentId" method="post" class="d-inline-block">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success rounded-pill px-3 py-1" style="font-size: 12px; padding: 5px 15px; box-shadow: none;">
                                                    <i class="fa-solid fa-clipboard-check me-1"></i> Check-In
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <a asp-controller="Appointments" asp-action="Create" asp-route-patientId="@item.PatientId"
                                               class="btn btn-sm btn-primary-custom rounded-pill px-3 py-1 text-decoration-none"
                                               style="font-size: 12px; padding: 5px 15px; box-shadow: none;">
                                                <i class="fa-solid fa-calendar-plus me-1"></i> Book Appt
                                            </a>
                                        }
                                        <button type="button" class="table-action-icon" title="Edit Patient"
                                                onclick="openEditPatientModal(@item.PatientId, '@safeFirst', '@safeLast', '@item.Gender', '@dobStr', '@safePhone', '@safeInsurance', '@safeAddress')">
                                            <i class="fa-solid fa-pen"></i>
                                        </button>
                                        <a asp-action="Details" asp-route-id="@item.PatientId" class="table-action-icon" title="View Patient Details">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <button type="button" class="table-action-icon danger-hover" title="Delete Patient"
                                                    onclick="openDeletePatientModal(@item.PatientId, '@safeFirst @safeLast')">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="pagination-wrapper">
            <span class="pagination-info">Showing 1 to @Model.Count() of @Model.Count() entries</span>
            <div class="pagination-controls">
                <a class="pagination-btn"><i class="fa-solid fa-angle-left"></i></a>
                <a class="pagination-btn active">1</a>
                <a class="pagination-btn"><i class="fa-solid fa-angle-right"></i></a>
            </div>
        </div>
    </div>
</div>

<!-- Create Patient Modal -->
<div class="modal fade" id="createPatientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-user-plus me-2"></i>Register New Patient</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">First Name</label>
                            <input type="text" name="FirstName" class="form-control rounded-3" placeholder="e.g. John" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Last Name</label>
                            <input type="text" name="LastName" class="form-control rounded-3" placeholder="e.g. Doe" required />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Gender</label>
                            <select name="Gender" class="form-select rounded-3" required>
                                <option value="">-- Select Gender --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Date of Birth</label>
                            <input type="date" name="Dob" class="form-control rounded-3" required />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Phone Number</label>
                            <input type="text" name="Phone" class="form-control rounded-3" placeholder="e.g. 0912345678" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Insurance Number (BHYT)</label>
                            <input type="text" name="InsuranceNo" class="form-control rounded-3" placeholder="e.g. DN4012345678" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold small text-muted">Residential Address</label>
                        <textarea name="Address" rows="2" class="form-control rounded-3" placeholder="Enter home address..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="fa-solid fa-user-plus me-1"></i> Register Patient
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Patient Modal -->
<div class="modal fade" id="editPatientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-warning text-dark rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-user-pen me-2"></i>Edit Patient Profile</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editPatientForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">First Name</label>
                            <input type="text" name="FirstName" id="editPatientFirstName" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Last Name</label>
                            <input type="text" name="LastName" id="editPatientLastName" class="form-control rounded-3" required />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Gender</label>
                            <select name="Gender" id="editPatientGender" class="form-select rounded-3" required>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Date of Birth</label>
                            <input type="date" name="Dob" id="editPatientDob" class="form-control rounded-3" required />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Phone Number</label>
                            <input type="text" name="Phone" id="editPatientPhone" class="form-control rounded-3" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-muted">Insurance Number (BHYT)</label>
                            <input type="text" name="InsuranceNo" id="editPatientInsurance" class="form-control rounded-3" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label fw-bold small text-muted">Residential Address</label>
                        <textarea name="Address" id="editPatientAddress" rows="2" class="form-control rounded-3"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">
                        <i class="fa-solid fa-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deletePatientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-danger text-white rounded-top-4">
                <h5 class="modal-title"><i class="fa-solid fa-trash-alt me-2"></i>Delete Patient</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <i class="fa-solid fa-exclamation-triangle fa-3x text-danger mb-3"></i>
                <p class="mb-1">Are you sure you want to delete:</p>
                <p class="fw-bold fs-6" id="deletePatientName"></p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0 pt-0 justify-content-center">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <form id="deletePatientForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger rounded-pill px-4">
                        <i class="fa-solid fa-trash-alt me-1"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditPatientModal(id, firstName, lastName, gender, dob, phone, insurance, address) {
            document.getElementById('editPatientFirstName').value = firstName;
            document.getElementById('editPatientLastName').value = lastName;
            document.getElementById('editPatientGender').value = gender;
            document.getElementById('editPatientDob').value = dob;
            document.getElementById('editPatientPhone').value = phone;
            document.getElementById('editPatientInsurance').value = insurance;
            document.getElementById('editPatientAddress').value = address;
            document.getElementById('editPatientForm').action = '/Patients/Edit/' + id;
            new bootstrap.Modal(document.getElementById('editPatientModal')).show();
        }

        function openDeletePatientModal(id, name) {
            document.getElementById('deletePatientName').textContent = name;
            document.getElementById('deletePatientForm').action = '/Patients/Delete/' + id;
            new bootstrap.Modal(document.getElementById('deletePatientModal')).show();
        }
    </script>
}
