@model MyProject.Application.DTOs.UpdatePatientRequest

@{
    ViewData["Title"] = "Edit Patient Profile";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3">
                    <h5 class="m-0 fw-bold text-primary"><i class="fa-solid fa-user-pen me-2"></i>Edit Patient Profile</h5>
                </div>
                <div class="card-body p-4">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            <div asp-validation-summary="All" class="text-danger small"></div>
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label fw-bold small text-muted">First Name</label>
                                <input asp-for="FirstName" class="form-control rounded-3" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label fw-bold small text-muted">Last Name</label>
                                <input asp-for="LastName" class="form-control rounded-3" required />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Gender" class="form-label fw-bold small text-muted">Gender</label>
                                <select asp-for="Gender" class="form-select rounded-3" required>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Dob" class="form-label fw-bold small text-muted">Date of Birth</label>
                                <input asp-for="Dob" type="date" class="form-control rounded-3" required />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-bold small text-muted">Phone Number</label>
                                <input asp-for="Phone" class="form-control rounded-3" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="InsuranceNo" class="form-label fw-bold small text-muted">Insurance Number (BHYT)</label>
                                <input asp-for="InsuranceNo" class="form-control rounded-3" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Address" class="form-label fw-bold small text-muted">Residential Address</label>
                            <textarea asp-for="Address" rows="3" class="form-control rounded-3"></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
