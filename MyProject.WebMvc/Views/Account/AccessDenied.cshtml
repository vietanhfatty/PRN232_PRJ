@{
    ViewData["Title"] = "Access Denied";
}

<div class="container text-center mt-5 py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-danger mb-4">
                        <i class="fa-solid fa-triangle-exclamation fa-5x"></i>
                    </div>
                    <h1 class="h3 mb-3 text-dark fw-bold">Unauthorized Access</h1>
                    <p class="text-muted mb-4">You do not have permission to access this page. Delete operations and configurations are restricted to Administrators only.</p>
                    <a href="/" class="btn btn-primary px-4 py-2 rounded-3">
                        <i class="fa-solid fa-home me-2"></i> Go to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
