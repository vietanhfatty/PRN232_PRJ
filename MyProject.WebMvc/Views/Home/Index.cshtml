@model MyProject.WebMvc.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard Overview";
    var currentUser = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Admin";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-slate-800 fw-bold">Hospital Overview</h1>
            <p class="text-muted small mb-0">Good morning, @currentUser. Here is what's happening at ASM 1 today.</p>
        </div>
        <div class="d-flex gap-3">
            <a asp-controller="Patients" asp-action="Create" class="btn-primary-custom">
                <i class="fa-solid fa-user-plus"></i> Register Patient
            </a>
            <a asp-controller="DoctorSchedules" asp-action="Create" class="btn-secondary-custom">
                <i class="fa-solid fa-calendar-plus"></i> Schedule Doctor
            </a>
        </div>
    </div>

    <!-- Stat Cards Row -->
    <div class="stat-card-row">
        <div class="stat-card">
            <div class="stat-card-icon-wrapper icon-blue">
                <i class="fa-solid fa-users-viewfinder"></i>
            </div>
            <div class="stat-card-info">
                <span class="stat-card-label">Total Patients</span>
                <span class="stat-card-value">@Model.TotalPatientsCount</span>
            </div>
            <span class="stat-card-trend trend-up">+4%</span>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon-wrapper icon-green">
                <i class="fa-solid fa-user-doctor"></i>
            </div>
            <div class="stat-card-info">
                <span class="stat-card-label">Active Doctors</span>
                <span class="stat-card-value">@Model.ActiveDoctorsCount</span>
            </div>
            <span class="stat-card-trend trend-up">Active</span>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon-wrapper icon-orange">
                <i class="fa-solid fa-hourglass-half"></i>
            </div>
            <div class="stat-card-info">
                <span class="stat-card-label">Waiting Queue</span>
                <span class="stat-card-value">@Model.WaitingQueueCount</span>
            </div>
            <span class="stat-card-trend trend-live">Live</span>
        </div>

        <div class="stat-card">
            <div class="stat-card-icon-wrapper icon-purple">
                <i class="fa-solid fa-calendar-check"></i>
            </div>
            <div class="stat-card-info">
                <span class="stat-card-label">Today's Appointments</span>
                <span class="stat-card-value">@Model.TodayAppointmentsCount</span>
            </div>
            <span class="stat-card-trend trend-neutral">Today</span>
        </div>
    </div>

    <!-- Grid Columns -->
    <div class="dashboard-grid">
        <!-- Recent Checkins -->
        <div class="modern-card modern-table-card">
            <div class="modern-table-header">
                <h5 class="modern-table-title">Recent Check-ins</h5>
                <span class="modern-badge badge-active" style="font-size: 11px;">
                    <i class="fa-solid fa-circle" style="font-size: 6px;"></i> SIGNALR CONNECTED
                </span>
            </div>
            <div class="table-responsive">
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th>Patient Name</th>
                            <th>Department</th>
                            <th>Doctor</th>
                            <th>Check-In</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.RecentCheckIns.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    No check-ins registered for today.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model.RecentCheckIns)
                            {
                                var initials = "PT";
                                if (!string.IsNullOrEmpty(item.PatientName))
                                {
                                    var parts = item.PatientName.Split(' ');
                                    if (parts.Length > 1) {
                                        initials = (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
                                    } else if (parts.Length == 1) {
                                        initials = parts[0][0].ToString().ToUpper();
                                    }
                                }

                                var dept = "General Clinic";
                                if (!string.IsNullOrEmpty(item.DoctorName))
                                {
                                    if (item.DoctorName.Contains("Fleming") || item.DoctorName.Contains("Thorne")) { dept = "Cardiology"; }
                                    else if (item.DoctorName.Contains("Connor") || item.DoctorName.Contains("Jenkins")) { dept = "Neurology"; }
                                    else if (item.DoctorName.Contains("Sloan")) { dept = "Emergency"; }
                                    else if (item.DoctorName.Contains("Sarah")) { dept = "Pediatrics"; }
                                }

                                var avatarClasses = new[] { "avatar-blue", "avatar-indigo", "avatar-purple", "avatar-pink", "avatar-emerald", "avatar-rose" };
                                var avatarClass = avatarClasses[Math.Abs(item.PatientId) % avatarClasses.Length];

                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar-circle @avatarClass">
                                                @initials
                                            </div>
                                            <div class="d-flex flex-column">
                                                <span class="fw-bold text-slate-800">@item.PatientName</span>
                                                <span class="text-muted" style="font-size: 11px;">ID: #PT-@item.PatientId</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@dept</td>
                                    <td>Dr. @item.DoctorName</td>
                                    <td>@item.AppointmentDate.ToString("hh:mm tt")</td>
                                    <td>
                                        @if (item.Status == "Waiting")
                                        {
                                            <span class="modern-badge badge-waiting">Waiting</span>
                                        }
                                        else if (item.Status == "Completed" || item.Status == "Active")
                                        {
                                            <span class="modern-badge badge-active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="modern-badge badge-scheduled">Scheduled</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="py-3 text-center border-top">
                <a asp-controller="Appointments" asp-action="Index" class="fw-bold text-decoration-none" style="font-size: 13px; color: var(--primary);">View All Check-ins</a>
            </div>
        </div>

        <!-- Right Side Widgets -->
        <div>

        </div>
    </div>
</div>
