@model IEnumerable<MyProject.Application.DTOs.MedicalRecordDto>

@{
    ViewData["Title"] = "Medical Records Directory";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800"><i class="fa-solid fa-file-medical text-primary me-2"></i>Medical Records</h1>
            <p class="text-muted small mb-0">Browse and manage all medical records across the hospital.</p>
        </div>
    </div>

    <!-- Records Table Card -->
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white py-3">
            <h6 class="m-0 fw-bold text-primary">Records Repository (@Model.Count() files)</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase font-monospace fs-7">
                        <tr>
                            <th class="ps-4">Record ID</th>
                            <th>Patient Name</th>
                            <th>Doctor In Charge</th>
                            <th>Date Created</th>
                            <th>Diagnosis</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="fa-solid fa-folder-open fa-3x mb-3 text-primary"></i>
                                    <p class="mb-0 fw-bold">No medical records found!</p>
                                    <p class="small text-muted mb-0">Records will appear here once doctors complete appointments.</p>
                                </td>
                            </tr>
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">#@item.MedicalRecordId</td>
                                <td class="fw-bold text-dark">@item.PatientName</td>
                                <td>@item.DoctorName</td>
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <span class="text-dark fw-bold">
                                        @(string.IsNullOrEmpty(item.Diagnosis) ? "N/A" : item.Diagnosis.Length > 40 ? item.Diagnosis.Substring(0, 37) + "..." : item.Diagnosis)
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@item.MedicalRecordId" class="btn btn-sm btn-primary rounded-pill px-3">
                                        <i class="fa-solid fa-folder-open me-1"></i> Open File
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
